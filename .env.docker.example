# Docker 部署专用环境变量模板
# 使用前先复制：
# cp .env.docker.example .env.docker

# TapTouch 登录信息
TAPTOUCH_EMAIL=your-email@example.com
TAPTOUCH_PASSWORD=your-password

# 对外暴露端口（docker-compose 会映射到宿主机）
PORT=3001

# 运行目标
DEPLOY_TARGET=docker
DATA_DIR=/app/data
TAPTOUCH_SCRAPER_MODE=inline

# 自动同步
TAPTOUCH_AUTO_SYNC=true
TAPTOUCH_AUTO_FETCH_MS=300000
TAPTOUCH_COOKIE_REFRESH_MS=1800000

# 详情抓取策略
TAPTOUCH_PREFETCH_DETAILS=false
TAPTOUCH_DETAIL_PRIME_COUNT=0
TAPTOUCH_DETAIL_CONCURRENCY=4
TAPTOUCH_DETAIL_PREFETCH_WORKERS=1
TAPTOUCH_DETAIL_SAVE_EVERY=10

# 如需额外 Chromium 参数，可继续追加
# TAPTOUCH_BROWSER_ARGS=--window-size=1440,900
