# TapTouch 登录信息。只需要本地复制为 .env.local 后填写，不要提交真实账号密码。
TAPTOUCH_EMAIL=your-email@example.com
TAPTOUCH_PASSWORD=your-password

# Dashboard 端口
PORT=3001

# 使用 puppeteer-core 后不会自动下载 Chromium；如脚本找不到 Chrome，可手动指定。
# macOS 示例：/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux 示例：/usr/bin/chromium 或 /usr/bin/google-chrome
# TAPTOUCH_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# 默认开启自动同步；未配置账号密码时会自动跳过，不影响 Dashboard 启动。
TAPTOUCH_AUTO_SYNC=true
TAPTOUCH_AUTO_FETCH_MS=300000
TAPTOUCH_COOKIE_REFRESH_MS=1800000

# 主同步默认只抓核心数据和预热最近 8 笔收据，订单详情按需抓，减少服务器压力。
TAPTOUCH_PREFETCH_DETAILS=false
TAPTOUCH_DETAIL_PRIME_COUNT=8
TAPTOUCH_DETAIL_CONCURRENCY=4
TAPTOUCH_DETAIL_PREFETCH_WORKERS=2
TAPTOUCH_DETAIL_SAVE_EVERY=10
